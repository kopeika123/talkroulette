FROM node:22-bookworm-slim AS base
WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ARG NEXT_PUBLIC_API_URL=http://localhost:5000
ARG NEXT_PUBLIC_LIVEKIT_URL=
ARG NEXT_PUBLIC_VK_APP_ID=
ARG NEXT_PUBLIC_VK_REDIRECT_URL=
ARG NEXT_PUBLIC_YANDEX_CLIENT_ID=
ARG NEXT_PUBLIC_YANDEX_REDIRECT_URL=

ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_LIVEKIT_URL=$NEXT_PUBLIC_LIVEKIT_URL
ENV NEXT_PUBLIC_VK_APP_ID=$NEXT_PUBLIC_VK_APP_ID
ENV NEXT_PUBLIC_VK_REDIRECT_URL=$NEXT_PUBLIC_VK_REDIRECT_URL
ENV NEXT_PUBLIC_YANDEX_CLIENT_ID=$NEXT_PUBLIC_YANDEX_CLIENT_ID
ENV NEXT_PUBLIC_YANDEX_REDIRECT_URL=$NEXT_PUBLIC_YANDEX_REDIRECT_URL
ENV NODE_ENV=production
ENV PORT=3000
ENV TURBOPACK_ROOT=/app

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start"]
